---
interface Props {
  heading?: string;
  description?: string;
}

const { heading = "Get Your Free Estimate!", description = "Get your free estimate today and discover affordable, reliable garage door solutions. Our team provides transparent pricing and expert advice to help you make informed decisions, all at no cost to you." } = Astro.props;
---

<section class="py-16 bg-white" id="estimate">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
    <div>
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">{heading}</h2>
      <p class="text-gray-600 leading-relaxed mb-6">{description}</p>
      <div class="space-y-3">
        <p class="flex items-center gap-3 text-gray-700">
          <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          6719 Gall Blvd, Zephyrhills, FL 33542, USA
        </p>
        <p class="flex items-center gap-3 text-gray-700">
          <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          <a href="tel:8137987764" class="hover:text-accent">813-798-7764</a>
        </p>
        <p class="flex items-center gap-3 text-gray-700">
          <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Open 24 Hours
        </p>
      </div>
    </div>

    <form class="space-y-4 bg-gray-light p-8 rounded-lg" action="#" method="POST">
      <input type="text" name="name" placeholder="Name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors" />
      <input type="email" name="email" placeholder="Email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors" />
      <input type="tel" name="phone" placeholder="Phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors" />
      <textarea name="message" placeholder="Message" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors resize-vertical"></textarea>
      <button type="submit" class="w-full bg-accent text-white font-heading text-xl tracking-wide py-4 rounded-lg hover:bg-red-700 transition-colors">SEND</button>
    </form>
  </div>
</section>
