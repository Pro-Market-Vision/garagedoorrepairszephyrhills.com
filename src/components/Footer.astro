---
const serviceLinks = [
  { name: "Garage Door Installation", href: "/contact" },
  { name: "Garage Door Opener Repair", href: "/contact" },
  { name: "Commercial Garage Door Services", href: "/contact" },
  { name: "Garage Door Spring Repair", href: "/contact" },
  { name: "Garage Door Keypad Repair", href: "/contact" },
  { name: "Emergency Garage Door Services", href: "/contact" },
];
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href="/" aria-label="ASAP Zephyrhills Garage Door Repair homepage">
          <img src="/images/logo-white.png" alt="ASAP Zephyrhills Garage Door Repair logo" class="h-14 w-auto mb-4" />
        </a>
        <p class="text-gray-300 text-sm leading-relaxed">
          We specialize in providing top-notch garage door repair, installation, and maintenance for residential and commercial properties in Zephyrhills, FL and surrounding areas.
        </p>
      </div>

      <div>
        <h3 class="font-heading text-xl tracking-wide mb-4">Contact Information</h3>
        <div class="space-y-2 text-gray-300 text-sm">
          <p class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            6719 Gall Blvd Suite 214, Zephyrhills, FL 33542
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <span><a href="tel:4075578876" class="hover:text-white">(407) 557-8876</a> / <a href="tel:8137987764" class="hover:text-white">(813) 798-7764</a></span>
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Open 24 Hours
          </p>
        </div>
      </div>

      <div>
        <h3 class="font-heading text-xl tracking-wide mb-4">Our Services</h3>
        <ul class="space-y-2">
          {serviceLinks.map((s) => (
            <li><a href={s.href} class="text-gray-300 text-sm hover:text-white transition-colors">{s.name}</a></li>
          ))}
        </ul>
        <div class="mt-4 space-y-1">
          <a href="/about-us" class="block text-gray-300 text-sm hover:text-white transition-colors">About Us</a>
          <a href="/contact" class="block text-gray-300 text-sm hover:text-white transition-colors">Contact Us</a>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-gray-600">
    <div class="max-w-7xl mx-auto px-4 py-4">
      <p class="text-gray-400 text-sm text-center">&copy; {currentYear} ASAP Zephyrhills Garage Door Repair. All Rights Reserved.</p>
    </div>
  </div>
</footer>
