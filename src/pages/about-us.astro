---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="About Us | ASAP Zephyrhills Garage Door Repair">
  <section class="relative bg-primary text-white py-20 md:py-24">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">About Us</h1>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">About Us in Garage Door Repair in ASAP Zephyrhills</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          At ASAP Zephyrhills, we pride ourselves on offering reliable and affordable garage door repair services. With a team of skilled technicians, we provide fast, high-quality solutions for all your garage door needs, from spring replacements to opener repairs. Our commitment to excellent customer service ensures that you receive efficient, cost-effective repairs every time, making us the trusted choice for garage door services in Zephyrhills.
        </p>
        <a href="/contact" class="inline-flex bg-accent text-white font-heading text-lg tracking-wide px-6 py-3 rounded hover:bg-red-700 transition-colors">GET A QUICK QUOTE</a>
      </div>
      <div>
        <img src="/images/about.png" alt="Garage Door Repair" class="rounded-lg shadow-lg w-full" />
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Our Lovely Clients Says</h2>
      <p class="text-gray-600">Our lovely clients say great things about us! From fast response times to professional service, we pride ourselves on delivering exceptional garage door solutions that exceed expectations. Hear firsthand why so many trust us for their garage door needs!</p>
    </div>
  </section>

  <ContactForm />
</Layout>
