---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import services from '../data/services.json';
---

<Layout title="ASAP Zephyrhills Garage Door Repair | Expert Garage Door Services">

  <!-- Hero -->
  <section class="relative bg-primary text-white py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/hero.jpg')"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="max-w-2xl">
        <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Garage Door Repair in ASAP Zephyrhills</h1>
        <p class="text-gray-300 text-lg leading-relaxed mb-6">
          Garage Door Repair in ASAP Zephyrhills specializes in fast, reliable, and affordable garage door solutions. Their expert team handles repairs, installations, and maintenance for all types of garage doors, ensuring smooth operation and enhanced security.
        </p>
        <p class="flex items-center gap-2 text-gray-300 mb-6">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          6719 Gall Blvd, Zephyrhills, FL 33542, USA
        </p>
        <a href="tel:8137987764" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-red-700 transition-colors">
          Call Now 813-798-7764
        </a>
      </div>
    </div>
  </section>

  <!-- Expert Services -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Expert Garage Door Repair in Zephyrhills</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          Get fast and reliable garage door repair services in Zephyrhills with ASAP Garage Services. From repairs to installations, we ensure your garage doors operate safely and efficiently.
        </p>
        <a href="/about-us" class="inline-flex bg-primary text-white font-heading text-lg tracking-wide px-6 py-3 rounded hover:bg-dark transition-colors">LEARN MORE</a>
      </div>
      <div>
        <img src="/images/about.png" alt="Expert Garage Door Repair" class="rounded-lg shadow-lg w-full" />
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-6">What We Do</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        At ASAP Zephyrhills, we provide comprehensive garage door solutions including broken springs, cables, tracks, opener issues, panel replacement, and installations. We emphasize regular maintenance, quality parts, and affordable service. Contact ASAP Garage Services today to experience what we do best — delivering exceptional garage door solutions you can rely on.
      </p>
      <a href="tel:8137987764" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-red-700 transition-colors">Call Now 813-798-7764</a>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-4">Why Choose Us</h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-10">We offer fast response times, skilled technicians, affordable pricing, and a commitment to quality. Your satisfaction and safety are our top priorities!</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
        {[
          { name: "Fast & Reliable", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
          { name: "Transparent Pricing", icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "Customer Satisfaction", icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" },
          { name: "Accepts Credit Card", icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" },
          { name: "Emergency 24/7", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "Quality Tools", icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" },
          { name: "Expert Technicians", icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
        ].map((f) => (
          <div class="text-center p-6 bg-gray-light rounded-lg">
            <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon} /></svg>
            </div>
            <h3 class="font-heading text-lg tracking-wide text-primary">{f.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Emergency -->
  <section class="relative py-20 text-white">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/services/Emergency-Garage-Door-Services.jpg')"></div>
    <div class="absolute inset-0 bg-primary/85"></div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Emergency Garage Door Services</h2>
      <p class="text-gray-300 leading-relaxed mb-8">
        Our Emergency Garage Door Services provide fast, reliable solutions when you need them most. Whether it's a broken spring, malfunctioning opener, or stuck door, our expert technicians are available to restore your garage door's functionality quickly and efficiently.
      </p>
      <a href="tel:8137987764" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-red-700 transition-colors">Call Now 813-798-7764</a>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-white" id="services">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-2">Our Garage Door Repair Services</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">From fixing broken springs to replacing openers, we provide fast, reliable, and affordable solutions to keep your garage doors in top condition.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <div class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-border/30">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={s.image} alt={s.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">{s.name}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{s.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Our Lovely Clients Says</h2>
      <p class="text-gray-600">Our lovely clients say great things about us! From fast response times to professional service, we pride ourselves on delivering exceptional garage door solutions that exceed expectations.</p>
    </div>
  </section>

  <ContactForm />
</Layout>
